import numpy as np
import matplotlib.pyplot as plt

fig, axs = plt.subplots(1, 2, figsize=(10, 5)) 

n = 10
x = np.arange(n)
y = [5,6,6,6,7,8,9,9,10,10]

x_labels = ['Magyarország','Belgium','Ausztrália','Csehország','Ausztria',
            'Németország','Svédország','Izland','Dánia','Hollandia']

y_labels = ['177cm','178cm','178cm','178cm','179cm','180cm','181cm','181cm','182cm','182cm']

axs[0].bar(x, y, color='#42f5cb')   
axs[0].set_xticks(x)       
axs[0].set_xticklabels(x_labels, rotation=45, ha='right')    
axs[0].set_yticks(y)          
axs[0].set_yticklabels(y_labels)    
axs[0].set_title("Férfiak átlagmagassága")   
axs[0].set_ylabel('Magasságok')
axs[0].set_xlabel('országok')

                                 
n = 10
x = np.arange(n)
y2 = [7,7,7,8,8,9,9,9,10,10]

x_labels2 = ['Görögország','Lengyelország','Csehország','Belgium','Ausztria',
             'Németország','Svédország','Hollandia','Izland','Dánia']

y_labels2 = ['165cm','165cm','165cm','166cm','166cm','167cm','167cm','167cm','168cm','168cm']

axs[1].bar(x, y2, color='#8442f5')
axs[1].set_xticks(x)
axs[1].set_xticklabels(x_labels2, rotation=45, ha='right')  
axs[1].set_yticks(y2)
axs[1].set_yticklabels(y_labels2)
axs[1].set_title("Nők átlagmagassága")
axs[1].set_ylabel('Magasságok')
axs[1].set_xlabel('országok')

plt.tight_layout() 
plt.show()


import numpy as np
import matplotlib.pyplot as plt

x_labels = []
y_labels = []
y = []

with open("férfi_magasságok.txt", "r") as file:
    for line in file:
        line = line.strip()

        if line.count(",") == 2: 
            orszag, magasag, y_ertek = line.split(',')

            x_labels.append(orszag)
            y_labels.append(magasag)
            y.append(int(y_ertek))


x_labels2 = []
y_labels2 = []
y2 = []

with open("női_magasságok.txt", "r") as file:
    for line in file:
        line = line.strip()

        if line.count(",") == 2:
            orszag, magassag, y_ertek = line.split(',')

            x_labels2.append(orszag)
            y_labels2.append(magassag)
            y2.append(int(y_ertek))

fig, axs = plt.subplots(1, 2, figsize=(10, 5))

x = np.arange(len(y))

axs[0].bar(x, y, color='#42f5cb')
axs[0].set_xticks(x)
axs[0].set_xticklabels(x_labels, rotation=45, ha='right')
axs[0].set_yticks(y)
axs[0].set_yticklabels(y_labels)
axs[0].set_title("Férfiak átlagmagassága")
axs[0].set_ylabel('Magasságok')
axs[0].set_xlabel('országok')


x2 = np.arange(len(y2))

axs[1].bar(x2, y2, color='#8442f5')
axs[1].set_xticks(x2)
axs[1].set_xticklabels(x_labels2, rotation=45, ha='right')
axs[1].set_yticks(y2)
axs[1].set_yticklabels(y_labels2)
axs[1].set_title("Nők átlagmagassága")
axs[1].set_ylabel('Magasságok')
axs[1].set_xlabel('országok')

plt.tight_layout()
plt.show()
